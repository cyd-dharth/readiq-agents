# Postgres — db name is "postgres", schema is "readiq" (set via search_path in db.py)
DATABASE_URL=postgresql://postgres:root@localhost:5432/postgres
DB_SCHEMA=readiq

# Redis — used to dispatch generation jobs to readiq-agents
REDIS_URL=redis://redis:6379/0
JOB_QUEUE=book_generation

# LLM provider: anthropic | openai | gemini
# Set LLM_MODEL to a model that matches the provider, for example:
#   anthropic -> claude-sonnet-4-6
#   openai    -> gpt-4.1
#   gemini    -> gemini-2.5-flash
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite
MAX_OUTPUT_TOKENS=4000

# Set the key for whichever provider you use; the others can stay blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

UPLOAD_DIR=r"D:\readiq\books\source_ref"

# Free tier (5 req/min): keep retries high and concurrency low so the pipeline
# survives quota waits instead of failing. On a paid plan, raise concurrency
# and lower retries for full speed.
GEMINI_MAX_RETRIES=10
MAX_CONCURRENT_CHAPTER_SUMMARIES=2

# Caps every Gemini call project-wide to N requests per minute so calls are
# paced to the quota instead of bursting and hitting 429s. Set to your plan's
# actual quota (free tier: 5). Set to 0 to disable rate limiting entirely.
GEMINI_RATE_LIMIT_PER_MINUTE=10

# V1.1 research stage: web search provider for sourced critique and support.
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
MIN_SOURCES_PER_STANCE=2
MAX_SOURCES_PER_STANCE=6

# V1.2 embed stage: embedding provider for chapter-summary vectors (RAG chat).
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSIONS=1536

# Internal chat HTTP API: called only by the backend service, never public.
CHAT_API_HOST=0.0.0.0
CHAT_API_PORT=8001
MAX_CONTEXT_CHAPTERS=3
MAX_HISTORY_MESSAGES=8

